# ─── Fastify Ollama Proxy Dockerfile ─────────────────────
FROM node:20-slim

WORKDIR /app

# Install fastify and node-fetch
RUN npm init -y && npm install fastify@4 node-fetch@3

# Copy proxy code
COPY fastify-ollama-proxy.js .

ENV NODE_ENV=production

EXPOSE 3333

CMD ["node", "fastify-ollama-proxy.js"]
