# ═══════════════════════════════════════════════════════════════
# Meridian DLMM Bot — Local AI Configuration
# For: Jakarta Rig (AMD Ryzen 3 3100 + RX 580 8GB)
# ═══════════════════════════════════════════════════════════════

# ─── Wallet ──────────────────────────────────────────────────
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ─── Solana RPC ─────────────────────────────────────────────
# Helius recommended for reliability on mainnet
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ─── LLM Provider ──────────────────────────────────────────
# Option A: OpenRouter (cloud, costs money)
# OPENROUTER_API_KEY=sk-or-your_key_here

# Option B: Ollama (LOCAL, zero-cost, RX 580) ← RECOMMENDED
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.1:8b-instruct-q4_K_M

# Option C: LM Studio (alternative local)
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
# LLM_MODEL=your-model-from-lmstudio

# ─── API Keys ──────────────────────────────────────────────
HELIUS_API_KEY=your_helius_api_key_here
LPAGENT_API_KEY=your_lpagent_api_key_here

# ─── Telegram (optional, for remote control) ────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_USER_IDS=

# ─── Safety ─────────────────────────────────────────────────
# DRY_RUN=true = no on-chain transactions (RECOMMENDED for first run)
DRY_RUN=true

# ─── Fastify Proxy (optional, for Ollama quirks) ────────────
# If Ollama's /v1 endpoint has issues with tool_choice or system role,
# start the Fastify proxy and point LLM_BASE_URL here instead:
# LLM_BASE_URL=http://localhost:3333/v1
FASTIFY_PROXY_PORT=3333
FASTIFY_PROXY_TARGET=http://localhost:11434/v1

# ─── Resource Constraints ──────────────────────────────────
# Limit Node.js heap to ~512MB, leaving RAM for Ollama
# Start bot with: NODE_OPTIONS="--max-old-space-size=512" node index.js
NODE_OPTIONS=--max-old-space-size=512

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=info
ALLOW_SELF_UPDATE=false

# ─── RX 580 Specific (Linux/ROCm) ──────────────────────────
# If running Linux, set this for Ollama to use ROCm with Polaris:
# HSA_OVERRIDE_GFX_VERSION=8.0.3
# If running Windows, Ollama uses DirectML automatically — no env vars needed.

# ─── Database (for persistent logging via this dashboard) ───
DATABASE_URL=file:./db/custom.db
