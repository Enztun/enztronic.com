# ─── Meridian Bot Dockerfile ───────────────────────────────────
# Build context: project root (deploy/docker-compose.yml sets context: ..)
#
# PREREQUISITE: Meridian must be cloned first:
#   git clone https://github.com/yunus-0x/meridian repos/meridian
#
# The bot's JSON state files (state.json, decision-log.json, lessons.json,
# pool-memory.json) land in /data (a named Docker volume shared with the
# sidecar) by running the bot with `cd /data && node /app/index.js`.

FROM node:20-slim AS builder

WORKDIR /app

# Install Meridian dependencies
COPY repos/meridian/package.json repos/meridian/package-lock.json ./
RUN npm ci --only=production

# Copy Meridian source
COPY repos/meridian/ .

# Overlay our Ollama-tuned user-config (replaces any default in the repo)
COPY deploy/user-config.ollama.json ./user-config.json

# ─── Runtime ──────────────────────────────────────────────────
FROM node:20-slim

WORKDIR /app

COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app .

ENV NODE_OPTIONS=--max-old-space-size=512
ENV NODE_ENV=production

# /data is the named volume where all JSON state files are written
RUN mkdir -p /data

HEALTHCHECK --interval=60s --timeout=10s --retries=3 \
  CMD node -e "process.exit(0)" || exit 1

# cd to /data so all relative paths (./state.json etc.) resolve there
CMD ["sh", "-c", "cd /data && exec node /app/index.js"]
